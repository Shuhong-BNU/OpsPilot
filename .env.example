# 应用基础配置
APP_NAME=OpsPilot
APP_TITLE=基于 RAG 与 MCP 的智能运维助手
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=9900

# 持久化与鉴权
DATABASE_PATH=./data/opspilot.db
JWT_SECRET=replace-with-a-secure-secret
JWT_EXPIRE_MINUTES=720
PASSWORD_HASH_ITERATIONS=120000

# 默认演示账号
DEFAULT_VIEWER_USERNAME=viewer
DEFAULT_VIEWER_PASSWORD=viewer123
DEFAULT_OPERATOR_USERNAME=operator
DEFAULT_OPERATOR_PASSWORD=operator123
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# DashScope / Qwen
DASHSCOPE_API_KEY=your-api-key
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

# RAG / 检索
RAG_TOP_K=3
RAG_MODEL=qwen-max
DENSE_TOP_K=6
SPARSE_TOP_K=6
HYBRID_TOP_K=4
RERANK_TOP_K=3
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# MCP 服务
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

# 指标
METRICS_ENABLED=True
